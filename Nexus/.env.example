# Local Postgres (docker-compose default)
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus

# Ollama via NGINX Basic Auth (host port from docker-compose nginx service)
# OLLAMA_URL=http://ollama-user:YOUR_PASSWORD@127.0.0.1:11435

# Sentry (app monitoring)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry → Nexus webhooks (Internal Integration Client Secret for HMAC)
SENTRY_WEBHOOK_CLIENT_SECRET=
# Local testing only — never in production
# SENTRY_WEBHOOK_SKIP_VERIFY=true
# Tenant row must exist (see db:seed); default slug dev
NEXUS_WEBHOOK_TENANT_SLUG=dev

# GitHub REST — branch + PR automation (Phase 6). Fine-grained PAT: Contents + Pull requests.
# GITHUB_TOKEN=
# GITHUB_OWNER=my-org-or-user
# GITHUB_REPO=my-repo

# Dashboard (Phase 7) — single shared secret for /login → cookie session
# NEXUS_DASHBOARD_SECRET=

# Phase 8+: Slack, etc.
